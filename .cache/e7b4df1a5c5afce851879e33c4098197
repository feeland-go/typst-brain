<span class="typ-func">#</span><span class="typ-func">slide</span><span class="typ-punct">(</span>
  repeat<span class="typ-punct">:</span> <span class="typ-num">3</span><span class="typ-punct">,</span>
  self <span class="typ-op">=&gt;</span> <span class="typ-punct">[</span>
    <span class="typ-key">#</span><span class="typ-key">let</span> <span class="typ-punct">(</span>uncover<span class="typ-punct">,</span> only<span class="typ-punct">,</span> alternatives<span class="typ-punct">)</span> <span class="typ-op">=</span> utils<span class="typ-punct">.</span><span class="typ-func">methods</span><span class="typ-punct">(</span>self<span class="typ-punct">)</span>

