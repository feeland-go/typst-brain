  <span class="typ-punct">[</span>Frog<span class="typ-punct">]</span><span class="typ-punct">,</span> <span class="typ-punct">[</span>Animal<span class="typ-punct">]</span><span class="typ-punct">,</span> <span class="typ-punct">[</span>6 <span class="typ-math-delim">$</span><span class="typ-str">"cm"</span><span class="typ-math-op">^</span>3<span class="typ-math-delim">$</span><span class="typ-punct">]</span><span class="typ-punct">,</span> <span class="typ-punct">[</span>Robert<span class="typ-punct">]</span><span class="typ-punct">,</span>
